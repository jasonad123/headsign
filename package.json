		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.34.1",
	"private": true,
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^24.12.2",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^4.0.1"
	}
