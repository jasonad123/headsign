{
	"name": "headsign-server",
	"version": "1.5.3",
	"main": "server/app.js",
	"dependencies": {
		"compression": "^1.8.1",
		"cookie-parser": "~1.4.7",
		"ejs": "~5.0.1",
		"errorhandler": "~1.5.2",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"morgan": "^1.10.1",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0"
	},
	"scripts": {
		"start": "node --env-file=.env server/app.js",
		"build": "cd svelte-app && pnpm install && pnpm build",
